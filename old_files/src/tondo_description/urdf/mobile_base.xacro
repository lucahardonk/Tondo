<?xml version="1.0"?>
<robot  xmlns:xacro="http://www.ros.org/wiki/xacro">
<!--no name overwrite, is reserved for the main file-->

    <xacro:property name="base_length" value="0.5"/>
    <xacro:property name="base_width" value="0.32"/>
    <xacro:property name="base_height" value="0.13"/>

    <xacro:property name="wheel_radius" value="0.125"/>
    <xacro:property name="wheel_width" value="0.06"/>

    

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>

            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
            <material name="blue" />
        </visual>

        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
        </collision>


        <xacro:box_inertia m="3.0" l="${2*base_length}" w="${2*base_width}" h="${2*base_height}"
                           xyz="0 0 0.1" rpy="0 0 0"/>
        
        
    </link>

  
    
    <link name="right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>

            <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
            <material name="black" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
        </collision>

        <xacro:cylinder_inertia m="1" r="${2*wheel_radius}" h="${2*wheel_width}" 
                                xyz="0 0 0" rpy="${pi/2.0} 0 0"/>

    </link>


    <link name="left_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>

            <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
            <material name="black" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
        </collision>

        <xacro:cylinder_inertia m="1" r="${2*wheel_radius}" h="${2*wheel_width}" 
                                xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
    </link>

    <!-- moved the 2 driving wheels foward
    <link name="foward_caster">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius/2}"/>
            </geometry>

            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="grey" />
        </visual>

        <collision>
            <geometry>
                <sphere radius="${wheel_radius/2}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>

        <xacro:sphere_inertia m="0.5" r="${2*wheel_radius/2}"  xyz="0 0 0" rpy="0 0 0"/>
    </link>
    -->

    <link name="rear_caster">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius/2}"/>
            </geometry>

            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="grey" />
        </visual>

        <collision>
            <geometry>
                <sphere radius="${wheel_radius/2}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>

        <xacro:sphere_inertia m="0.5" r="${2*wheel_radius/2}"  xyz="0 0 0" rpy="0 0 0"/>
    </link>




    <joint name="base_joint" type="fixed">
        <parent link="base_link" />
        <child link="base_footprint" />
        <origin xyz="0 0 -0.125" rpy="0 0 0" />
        <axis xyz="0 0 0" />
    </joint>


    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="0.15 +0.21 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="0.15 -0.21 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- moved the 2 driving wheels foward
    <joint name="base_foward_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="foward_caster" />
        <origin xyz="0.15 0 -${wheel_radius/2}" rpy="0 0 0" />
        <axis xyz="0 0 0" />
    </joint>
    -->

    <joint name="base_rear_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="rear_caster" />
        <origin xyz="-0.15 0 -${wheel_radius/2}" rpy="0 0 0" />
        <axis xyz="0 0 0" />
    </joint>


</robot>
