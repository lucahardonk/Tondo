        corrected_msg.angular_velocity.y = msg->angular_velocity.z;
        corrected_msg.angular_velocity.z = -msg->angular_velocity.y;

        // Modify linear acceleration values
        geometry_msgs::msg::Vector3 linear_acceleration;
        linear_acceleration.x = msg->linear_acceleration.x;
        linear_acceleration.y = msg->linear_acceleration.z;
