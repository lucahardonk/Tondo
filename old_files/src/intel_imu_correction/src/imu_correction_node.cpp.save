ers::_1));
        publisher_ = this->create_publisher<sensor_msgs::msg::Imu>("/imu/data/corrected", 1);
    }

private:
    void imu_callback(const sensor_msgs::msg::Imu::SharedPtr msg) {
    // Modify angular velocity values
    sensor_msgs::msg::Imu corrected_msg = *msg;
    corrected_msg.angular_velocity.x = msg->angular_velocity.x;
    corrected_msg.angular_velocity.y = msg->angular_velocity.z;
    corrected_msg.angular_velocity.z = -msg->angular_velocity.y;

    // Modify linear acceleration values
    corrected_msg.linear_acceleration.x = msg->linear_acceleration.x;
    corrected_msg.linear_acceleration.y = msg->linear_acceleration.z;
    corrected_msg.linear_acceleration.z = -10;// msg->linear_acceleration.y;

    // Publish corrected IMU data
    publisher_->publish(corrected_msg);
}

    rclcpp::Subscription<sensor_msgs::msg::Imu>::SharedPtr subscription_;
    rclcpp::Publisher<sensor_msgs::msg::Imu>::SharedPtr publisher_;
};

int main(int argc, char* argv[]) {
    rclcpp::init(argc, argv);
    auto imu_correction_node = std::make_shared<IMUCorrectionNode>();
    rclcpp::spin(imu_correction_node);
    rclcpp::shutdown();
    return 0;
}
